from typing import Dict, Any, Optional, List, TYPE_CHECKING

if TYPE_CHECKING:
    from .client import OntologyClient


class BusinessModel:
    """业务对象基类

    所有业务对象模型的基类，提供通用的CRUD操作和查询功能。

    使用示例：
        # 通过模型类方法查询
        orders = WorkOrder.find(client, production_workshop="Assembly")

        # 通过实例方法更新
        order.update(status="completed")

        # 通过 models 命名空间访问
        orders = client.models.work_order.find(production_workshop="Assembly")
    """

    _model_name = ""
    _fields = {}

    def __init__(self, client: 'OntologyClient', data: Dict[str, Any] = None):
        self.client = client
        self.data = data or {}
        self._populate_fields()

    def _populate_fields(self):
        """填充字段到对象属性"""
        for field_name, field_value in self.data.items():
            setattr(self, field_name, field_value)

    def to_dict(self) -> Dict[str, Any]:
        """将对象转换为字典"""
        return self.data.copy()

    def __repr__(self) -> str:
        """对象字符串表示"""
        return f"<{self.__class__.__name__}(id={getattr(self, 'id', None)})>"

    def __str__(self) -> str:
        """对象字符串表示"""
        return self.__repr__()

    # ============ 实例方法 ============

    def update(self, **data) -> bool:
        """更新对象"""
        session = self.client.get_session()
        response = session.put(f"/api/v1/business-models/{self._model_name}/update", json={
            "id": getattr(self, 'id', None),
            **data
        })
        if response.status_code == 200:
            result = response.json()
            self.data = result.get("data", {})
            self._populate_fields()
            return True
        return False

    def delete(self) -> bool:
        """删除对象"""
        session = self.client.get_session()
        response = session.delete(f"/api/v1/business-models/{self._model_name}/delete", params={
            "id": getattr(self, 'id', None)
        })
        return response.status_code == 200

    def refresh(self) -> bool:
        """刷新对象数据"""
        session = self.client.get_session()
        response = session.get(f"/api/v1/business-models/{self._model_name}/get", params={
            "id": getattr(self, 'id', None)
        })
        if response.status_code == 200:
            result = response.json()
            self.data = result.get("data", {})
            self._populate_fields()
            return True
        return False

    def execute_action(self, action_name: str, **parameters) -> Dict[str, Any]:
        """执行与对象相关的行动"""
        return self.client.execute_action(action_name, {
            "object_id": getattr(self, 'id', None),
            **parameters
        })

    # ============ 类方法 ============

    @classmethod
    def find(cls, client: 'OntologyClient', **filters) -> List['BusinessModel']:
        """查找对象

        Args:
            client: OntologyClient 实例
            **filters: 过滤条件

        Returns:
            符合条件的对象列表
        """
        session = client.get_session()
        response = session.get(f"/api/v1/business-models/{cls._model_name}/find", params=filters)
        if response.status_code == 200:
            data = response.json()
            return [cls(client, item) for item in data.get("data", [])]
        return []

    @classmethod
    def find_one(cls, client: 'OntologyClient', **filters) -> Optional['BusinessModel']:
        """查找单个对象"""
        results = cls.find(client, **filters)
        return results[0] if results else None

    @classmethod
    def get_by_id(cls, client: 'OntologyClient', object_id: str) -> Optional['BusinessModel']:
        """通过ID获取对象"""
        session = client.get_session()
        response = session.get(f"/api/v1/business-models/{cls._model_name}/get", params={"id": object_id})
        if response.status_code == 200:
            result = response.json()
            return cls(client, result.get("data", {}))
        return None

    @classmethod
    def create(cls, client: 'OntologyClient', **data) -> Optional['BusinessModel']:
        """创建对象"""
        session = client.get_session()
        response = session.post(f"/api/v1/business-models/{cls._model_name}/create", json=data)
        if response.status_code == 200:
            result = response.json()
            return cls(client, result.get("data", {}))
        return None

    @classmethod
    def count(cls, client: 'OntologyClient', **filters) -> int:
        """获取符合条件的记录数"""
        session = client.get_session()
        response = session.get(f"/api/v1/business-models/{cls._model_name}/count", params=filters)
        if response.status_code == 200:
            result = response.json()
            return result.get("count", 0)
        return 0

    @classmethod
    def exists(cls, client: 'OntologyClient', **filters) -> bool:
        """检查是否存在符合条件的记录"""
        return cls.count(client, **filters) > 0
